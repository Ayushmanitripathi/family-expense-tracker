<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.familyexpense.controllers.FamilySetupController"
            style="-fx-background-color:#EEF2FF;">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="0" minWidth="210" maxWidth="210">
            <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4">
                <Label text="&#128106;" style="-fx-font-size:32px;"/>
                <Label text="Family Setup" style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13px;"/>
                <Label text="Manage Members" style="-fx-text-fill:#94A3B8;-fx-font-size:11px;"/>
            </VBox>
            <Button text="&#127968;  Dashboard" styleClass="sidebar-btn" maxWidth="Infinity" onAction="#handleHome"/>
            <Button text="&#10133;  Add Expense" styleClass="sidebar-btn" maxWidth="Infinity" onAction="#handleAddExpense"/>
            <Button text="&#128203;  Expense History" styleClass="sidebar-btn" maxWidth="Infinity" onAction="#handleHistory"/>
            <Button text="&#128202;  Monthly Report" styleClass="sidebar-btn" maxWidth="Infinity" onAction="#handleReport"/>
            <Button text="&#128106;  Family Setup" styleClass="sidebar-btn,sidebar-btn-active" maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-background-color:#EEF2FF;">
            <VBox spacing="20" style="-fx-padding:28;-fx-background-color:#EEF2FF;">

                <!-- PAGE HEADER -->
                <VBox spacing="4">
                    <Label text="&#128106; Family Setup"
                           style="-fx-font-size:24px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    <Label text="Add or remove family members who track their expenses"
                           style="-fx-text-fill:#64748B;-fx-font-size:13px;"/>
                </VBox>

                <!-- ADD MEMBER CARD -->
                <VBox styleClass="card" spacing="16">
                    <Label text="&#10133; Add New Family Member"
                           style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    <Separator/>
                    <HBox spacing="14" alignment="BOTTOM_LEFT">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="&#128100; Name" styleClass="field-label"/>
                            <TextField fx:id="nameField"
                                       promptText="e.g. Papa, Mummy, Rahul, Priya..."
                                       styleClass="text-field-custom"
                                       prefHeight="42"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="&#128101; Role" styleClass="field-label"/>
                            <ComboBox fx:id="roleCombo"
                                      prefWidth="190"
                                      prefHeight="42"
                                      styleClass="combo-box-custom"/>
                        </VBox>
                        <Button text="&#10133; Add Member"
                                onAction="#handleAddMember"
                                styleClass="btn-primary"
                                style="-fx-font-size:14px;-fx-padding:12 24;"
                                prefHeight="42"/>
                    </HBox>
                    <Label fx:id="statusLabel" text=""
                           style="-fx-font-size:13px;-fx-font-weight:bold;"/>
                </VBox>

                <!-- MEMBER LIST -->
                <VBox styleClass="card" spacing="14">
                    <Label text="&#128101; Current Family Members"
                           style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    <Separator/>
                    <VBox fx:id="memberListPane" spacing="10"/>
                </VBox>

                <!-- TIPS BOX -->
                <VBox style="-fx-background-color:#F0FFF4;-fx-background-radius:12px;-fx-padding:16px;-fx-border-color:#06D6A0;-fx-border-radius:12px;-fx-border-width:1px;"
                      spacing="6">
                    <Label text="&#128161; Tips:"
                           style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#065F46;"/>
                    <Label text="• Deleting a member keeps their expense records intact"
                           style="-fx-font-size:12px;-fx-text-fill:#065F46;-fx-wrap-text:true;"/>
                    <Label text="• Added members will appear in the Add Expense dropdown"
                           style="-fx-font-size:12px;-fx-text-fill:#065F46;-fx-wrap-text:true;"/>
                    <Label text="• Each member can independently track their own spending"
                           style="-fx-font-size:12px;-fx-text-fill:#065F46;-fx-wrap-text:true;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
