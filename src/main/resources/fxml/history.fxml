<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.familyexpense.controllers.HistoryController"
            style="-fx-background-color:#EEF2FF;">
    <left>
        <VBox styleClass="sidebar" spacing="0" minWidth="210" maxWidth="210">
            <VBox styleClass="sidebar-header" alignment="CENTER" spacing="4">
                <Label text="&#128203;" style="-fx-font-size:30px;"/>
                <Label text="Expense History" style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13px;"/>
            </VBox>
            <Button text="&#127968;  Dashboard" styleClass="sidebar-btn" maxWidth="Infinity" onAction="#handleHome"/>
            <Button text="&#10133;  Add Expense" styleClass="sidebar-btn" maxWidth="Infinity" onAction="#handleAddExpense"/>
            <Button text="&#128203;  Expense History" styleClass="sidebar-btn,sidebar-btn-active" maxWidth="Infinity"/>
            <Button text="&#128202;  Monthly Report" styleClass="sidebar-btn" maxWidth="Infinity" onAction="#handleReport"/>
            <Button text="&#128106;  Family Setup" styleClass="sidebar-btn" maxWidth="Infinity" onAction="#handleFamily"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="16" style="-fx-padding:24;-fx-background-color:#EEF2FF;">
            <VBox spacing="3">
                <Label text="&#128203; Expense History" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                <Label fx:id="totalLabel" text="" style="-fx-text-fill:#4361EE;-fx-font-size:13px;-fx-font-weight:bold;"/>
            </VBox>

            <!-- FILTERS -->
            <VBox styleClass="card" spacing="12">
                <Label text="&#128269; Filter &amp; Search" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label text="Month" styleClass="field-label"/>
                        <ComboBox fx:id="monthFilter" prefWidth="130" styleClass="combo-box-custom"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Member" styleClass="field-label"/>
                        <ComboBox fx:id="memberFilter" prefWidth="130" styleClass="combo-box-custom"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Category" styleClass="field-label"/>
                        <ComboBox fx:id="categoryFilter" prefWidth="130" styleClass="combo-box-custom"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Search" styleClass="field-label"/>
                        <TextField fx:id="searchField" promptText="Note or name..."
                                   prefWidth="150" styleClass="text-field-custom" prefHeight="35"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text=" " styleClass="field-label"/>
                        <HBox spacing="8">
                            <Button text="Filter" onAction="#handleFilter"
                                    styleClass="btn-primary" style="-fx-padding:8 14;"/>
                            <Button text="Clear" onAction="#handleClearFilter"
                                    styleClass="btn-secondary" style="-fx-padding:8 12;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- TABLE -->
            <TableView fx:id="expenseTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="105"/>
                    <TableColumn fx:id="colMember" text="Member" prefWidth="130"/>
                    <TableColumn fx:id="colCategory" text="Category" prefWidth="135"/>
                    <TableColumn fx:id="colAmount" text="Amount" prefWidth="110"/>
                    <TableColumn fx:id="colNote" text="Note" prefWidth="190"/>
                    <TableColumn fx:id="colAction" text="Action" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
